<%# app/views/surveys/new.html.erb %>
<div class="survey-page">
  <div class="container py-4">
    <div class="text-center mb-4">
      <span class="badge-label mb-2 d-inline-block">ツアーコンディショニング</span>
      <h1 class="survey-title">ツアー前ヒアリング髭全体</h1>
      <p class="survey-subtitle">サポートをより良くするために、現在の状態を聞かせてください。</p>
    </div>

    <%= form_with model: @survey, url: surveys_path, method: :post, class: "survey-form" do |f| %>

      <!-- お名前 -->
      <div class="q-card">
        <%= f.label :respondent_name, "お名前", class: "q-label" %>
        <p class="q-note">名字のみカタカナで記入してください</p>
        <%= f.text_field :respondent_name, class: "form-control form-input", placeholder: "例：シマワキ", required: true, autocomplete: "off" %>
      </div>

      <!-- Q1 -->
      <div class="q-card">
        <p class="q-label">Q1. 今の身体の状態で、共有しておきたいことはありますか？</p>
        <p class="q-note">複数選択できます</p>
        <div class="check-list">
          <% HigeZentaiSurvey::Q1_OPTIONS.each do |opt| %>
            <label class="check-item">
              <%= f.check_box :q1, { multiple: true, class: "check-input" }, opt, nil %>
              <span class="check-body"><%= opt %></span>
            </label>
          <% end %>
        </div>
        <div class="other-field d-none" id="q1-other-field">
          <%= f.label :q1_other, "その他（具体的に）", class: "q-note mt-2" %>
          <%= f.text_area :q1_other, class: "form-control form-input", rows: 2, placeholder: "自由に記入してください" %>
        </div>
      </div>

      <!-- Q2 -->
      <div class="q-card">
        <p class="q-label">Q2. 今回のツアー中、より良い状態で過ごすために大切にしたいことはありますか？</p>
        <p class="q-note">複数選択できます</p>
        <div class="check-list">
          <% HigeZentaiSurvey::Q2_OPTIONS.each do |opt| %>
            <label class="check-item">
              <%= f.check_box :q2, { multiple: true, class: "check-input" }, opt, nil %>
              <span class="check-body"><%= opt %></span>
            </label>
          <% end %>
        </div>
        <div class="other-field d-none" id="q2-other-field">
          <%= f.label :q2_other, "その他（具体的に）", class: "q-note mt-2" %>
          <%= f.text_area :q2_other, class: "form-control form-input", rows: 2, placeholder: "自由に記入してください" %>
        </div>
      </div>

      <!-- Q3 -->
      <div class="q-card">
        <p class="q-label">Q3. 本番に向けて、特に良い状態にしておきたい部位はありますか？</p>
        <p class="q-note">複数選択できます</p>
        <div class="check-list">
          <% HigeZentaiSurvey::Q3_OPTIONS.each do |opt| %>
            <label class="check-item">
              <%= f.check_box :q3, { multiple: true, class: "check-input" }, opt, nil %>
              <span class="check-body"><%= opt %></span>
            </label>
          <% end %>
        </div>
        <div class="other-field d-none" id="q3-other-field">
          <%= f.label :q3_other, "その他（具体的に）", class: "q-note mt-2" %>
          <%= f.text_area :q3_other, class: "form-control form-input", rows: 2, placeholder: "自由に記入してください" %>
        </div>
      </div>

      <!-- Q4 -->
      <div class="q-card">
        <p class="q-label">Q4. フィジカル面で、サポートしてほしいことがあれば教えてください。</p>
        <p class="q-note">任意・自由記述</p>
        <%= f.text_area :q4, class: "form-control form-input", rows: 4, placeholder: "どんな小さなことでも、気になることがあれば気軽に書いてください。" %>
      </div>

      <div class="submit-wrap">
        <%= f.submit "送信する", class: "btn-submit" %>
      </div>

    <% end %>
  </div>
</div>

<style>
  @import url('https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@300;400;500;700&display=swap');

  * { box-sizing: border-box; }
  body { font-family: 'Noto Sans JP', sans-serif; background: #f7f6f3; color: #1a1a1a; margin: 0; }

  .survey-page { min-height: 100vh; }
  .container { max-width: 640px; }

  .badge-label {
    font-size: .72rem; font-weight: 500; letter-spacing: .1em;
    color: #5a7a6a; background: #e6f0eb; padding: .3em .9em;
    border-radius: 999px; text-transform: uppercase;
  }
  .survey-title {
    font-size: clamp(1.4rem, 4vw, 1.9rem); font-weight: 700;
    color: #1a1a1a; margin: .4rem 0 .3rem;
  }
  .survey-subtitle { font-size: .9rem; color: #666; margin: 0; }

  .q-card {
    background: #fff; border-radius: 16px; padding: 1.4rem 1.6rem;
    margin-bottom: 1rem; box-shadow: 0 2px 12px rgba(0,0,0,.06);
    border: 1px solid rgba(0,0,0,.06);
  }
  .q-label { font-weight: 600; font-size: 1rem; margin: 0 0 .3rem; line-height: 1.5; color: #1a1a1a; }
  .q-note { font-size: .8rem; color: #888; margin: 0 0 .8rem; }

  .check-list { display: flex; flex-direction: column; gap: .4rem; }
  .check-item { display: flex; align-items: center; gap: .6rem; cursor: pointer; }
  .check-input { display: none; }
  .check-body {
    flex: 1; padding: .75rem 1rem; border-radius: 10px;
    border: 1.5px solid #e0e0e0; background: #fafaf8;
    font-size: .92rem; transition: all .15s; user-select: none;
  }
  .check-input:checked + .check-body {
    border-color: #5a7a6a; background: #e6f0eb; color: #2d5a3d; font-weight: 500;
  }
  .check-body:hover { border-color: #5a7a6a; }

  .form-input {
    width: 100%; border: 1.5px solid #e0e0e0; border-radius: 10px;
    padding: .75rem 1rem; font-size: .92rem; font-family: inherit;
    background: #fafaf8; transition: border-color .15s;
  }
  .form-input:focus { outline: none; border-color: #5a7a6a; box-shadow: 0 0 0 3px rgba(90,122,106,.15); }

  .other-field { margin-top: .6rem; }

  .submit-wrap { text-align: center; margin: 1.5rem 0 2rem; }
  .btn-submit {
    background: #2d5a3d; color: #fff; border: none; border-radius: 12px;
    padding: .9rem 3rem; font-size: 1rem; font-weight: 600;
    font-family: inherit; cursor: pointer; transition: all .18s;
    box-shadow: 0 4px 16px rgba(45,90,61,.3);
  }
  .btn-submit:hover { background: #3d7a55; transform: translateY(-1px); }
</style>

<script>
  function watchOtherCheckbox(name, fieldId) {
    document.querySelectorAll(`[name="${name}"]`).forEach(cb => {
      if (cb.value === 'その他') {
        cb.addEventListener('change', () => {
          document.getElementById(fieldId).classList.toggle('d-none', !cb.checked);
        });
      }
    });
  }
  watchOtherCheckbox('hige_zentai_survey[q1][]', 'q1-other-field');
  watchOtherCheckbox('hige_zentai_survey[q2][]', 'q2-other-field');
  watchOtherCheckbox('hige_zentai_survey[q3][]', 'q3-other-field');
</script>
